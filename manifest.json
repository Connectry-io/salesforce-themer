{
  "manifest_version": 3,
  "name": "Salesforce Themer by Connectry",
  "version": "2.0.9",
  "description": "Transform your Salesforce experience with stunning themes. 16 handcrafted themes for Lightning Experience.",
  "permissions": ["storage", "activeTab", "tabs"],
  "host_permissions": [
    "https://*.salesforce.com/*",
    "https://*.lightning.force.com/*",
    "https://*.my.salesforce.com/*",
    "https://*.visualforce.com/*",
    "https://*.salesforce-setup.com/*",
    "https://*.cloudforce.com/*"
  ],
  "action": {
    "default_popup": "popup/popup.html",
    "default_icon": {
      "16": "icons/icon-16.png",
      "32": "icons/icon-32.png",
      "48": "icons/icon-48.png",
      "128": "icons/icon-128.png"
    }
  },
  "options_page": "options/options.html",
  "commands": {
    "toggle-theme": {
      "suggested_key": {
        "default": "Alt+Shift+T"
      },
      "description": "Cycle to next theme"
    },
    "toggle-dark-light": {
      "suggested_key": {
        "default": "Alt+Shift+D"
      },
      "description": "Toggle between dark and light mode"
    },
    "toggle-diagnostic": {
      "suggested_key": {
        "default": "Alt+D",
        "mac": "Alt+D"
      },
      "description": "Toggle theme diagnostic panel"
    }
  },
  "content_scripts": [
    {
      "matches": [
        "https://*.salesforce.com/*",
        "https://*.lightning.force.com/*",
        "https://*.my.salesforce.com/*",
        "https://*.visualforce.com/*",
        "https://*.salesforce-setup.com/*",
        "https://*.cloudforce.com/*"
      ],
      "js": [
        "core/effects/engine.js",
        "effects/effects.js",
        "effects/presets.js",
        "diagnostic/token-scanner.js",
        "diagnostic/component-scanner.js",
        "diagnostic/guided-testing.js",
        "diagnostic/fix-generator.js",
        "diagnostic/custom-patches.js",
        "diagnostic/engine-connector.js",
        "diagnostic/report-generator.js",
        "diagnostic/diagnostic-panel.js",
        "content/content.js"
      ],
      "run_at": "document_start",
      "all_frames": true
    }
  ],
  "background": {
    "service_worker": "background.js"
  },
  "web_accessible_resources": [
    {
      "resources": [
        "themes/themes.json",
        "content/themes/*.css",
        "effects/effects.js",
        "effects/presets.js",
        "favicons/*.svg",
        "diagnostic/diagnostic-panel.css"
      ],
      "matches": [
        "https://*.salesforce.com/*",
        "https://*.lightning.force.com/*",
        "https://*.my.salesforce.com/*",
        "https://*.visualforce.com/*",
        "https://*.salesforce-setup.com/*",
        "https://*.cloudforce.com/*"
      ]
    }
  ],
  "icons": {
    "16": "icons/icon-16.png",
    "32": "icons/icon-32.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  }
}
